# GitHub Issue Manager 설정
# 복사: cp .env.example .env  (그 후 .env 값 수정)

# 대상 로컬 리포 경로
REPO_PATH=/data/workspace/knowledgebuilder

# GitHub 리포 (owner/repo 형식) — 비어있으면 git remote에서 자동 감지
GITHUB_REPO=minwooking/knowledgebuilder

# GitHub 토큰 (이미 환경에 주입됨, 수동 설정시 사용)
# GITHUB_TOKEN=ghp_xxxxx

# 중복 감지 임계값 (0.0~1.0, 높을수록 엄격)
DUPLICATE_THRESHOLD=0.75

# N일 이상 미활동 이슈를 stale(종결 후보)로 간주
STALE_DAYS=30

# true 이면 실제 이슈 close/댓글 없이 로그만 출력
DRY_RUN=false
